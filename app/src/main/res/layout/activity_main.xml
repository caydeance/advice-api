<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <Button
        android:id="@+id/button_main_vent"
        style="@style/Widget.AppCompat.Button"
        android:layout_width="0dp"
        android:layout_height="364dp"
        android:backgroundTint="#F0A4DD"
        android:fontFamily="@font/outfit"
        android:fontWeight="500"
        android:text="@string/vent"
        android:textSize="30sp"

        app:layout_constraintBottom_toTopOf="@+id/button_main_quiz"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/button_main_quiz"
        style="@style/Widget.AppCompat.Button"

        android:layout_width="0dp"
        android:layout_height="364dp"
        android:backgroundTint="#311717"
        android:fontFamily="@font/montserrat"
        android:fontWeight="1000"
        android:text="@string/quiz"
        android:textSize="50sp"

        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/button_main_vent" />

</androidx.constraintlayout.widget.ConstraintLayout>

